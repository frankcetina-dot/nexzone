# ============================================
# NexZone - Variables de entorno
# Copia este archivo como .env y completa los valores
# ============================================

# Seguridad
SECRET_KEY=cambia-esta-clave-por-una-segura-y-aleatoria
JWT_SECRET=otra-clave-secreta-diferente-para-jwt

# MySQL (local o remoto)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=tu_password
MYSQL_DB=nexzone_db
MYSQL_PORT=3306

# Flask
FLASK_ENV=production
DEBUG=False
